# LLM Configuration - Using Local API Server
# The system connects to a local API server running on localhost:8080
# This matches the setup used in jsonoutputparser.py

# Local API Server Settings
LOCAL_API_URL=http://127.0.0.1:8080/v1
LOCAL_MODEL=Qwen2.5-1.5B-Instruct-Q4_K_M
LLM_TEMPERATURE=0.7
MAX_TOKENS=2048

# Agent Configuration
MAX_ITERATIONS=10
TIMEOUT_SECONDS=60

# Search Configuration
MAX_SEARCH_RESULTS=5

# Logging
LOG_LEVEL=INFO


