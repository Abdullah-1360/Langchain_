# LLM Provider Configuration
# Options: "local" for Qwen2.5 local model, "openai" for OpenAI API
LLM_PROVIDER=local
LLM_MODEL=qwen2.5-1.5b
LLM_TEMPERATURE=0.7
# 
# Local Model Configuration (for llama-cpp-python with Qwen2.5)
# Download model from: https://huggingface.co/Qwen/Qwen2.5-1.5B-Instruct-GGUF
LOCAL_MODEL_PATH=./models/qwen2.5-1.5b-instruct-q4_k.gguf
N_GPU_LAYERS=50          # Use -1 for full GPU acceleration, 0 for CPU-only
N_THREADS=4              # Number of CPU threads
CONTEXT_WINDOW=2048      # Context window size
# 
# OpenAI Configuration (used if LLM_PROVIDER=openai)
OPENAI_API_KEY=your-api-key-here
# 
# Agent Configuration
MAX_ITERATIONS=10
TIMEOUT_SECONDS=60
# 
# Search Configuration
MAX_SEARCH_RESULTS=5
# 
# Logging
LOG_LEVEL=INFO